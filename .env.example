# ============================================================
#  CNPS - Suivi des Recommandations
#  Copiez ce fichier en .env.local et renseignez vos valeurs
# ============================================================

# Environnement applicatif : dev | test | prod
APP_ENV=dev

# Clé secrète Symfony (générez-en une avec : php bin/console secrets:generate-keys)
APP_SECRET=changeme_generate_a_strong_random_key

# URI de base de l'application (utilisée pour les liens absolus)
DEFAULT_URI=http://localhost

# ------------------------------------------------------------
# Base de données MySQL
# Format : mysql://USER:PASSWORD@HOST:PORT/DB_NAME?serverVersion=8.0&charset=utf8mb4
# ------------------------------------------------------------
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@127.0.0.1:3307/cnps_recommandations?serverVersion=8.0&charset=utf8mb4"

# ------------------------------------------------------------
# Mailer (envoi d'emails)
# En développement, utilisez Mailpit (Docker) : smtp://127.0.0.1:1025
# En production, remplacez par votre serveur SMTP réel
# Exemples :
#   smtp://user:password@smtp.example.com:587
#   gmail+smtp://user:password@default
# ------------------------------------------------------------
MAILER_DSN=smtp://127.0.0.1:1025
