<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}CNPS — Suivi des Recommandations{% endblock %}</title>
    <link rel="icon" type="image/jpeg" href="{{ asset('favicon.jpg') }}">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --cnps-primary: #1F4E79;
            --cnps-primary-dark: #163958;
            --cnps-primary-light: #2E75B6;
            --cnps-teal: #14B8A6;
            --cnps-teal-light: #5EEAD4;
            --cnps-accent: #C00000;
            --cnps-bg: #F8FAFC;
            --cnps-border: #E5E7EB;
            --cnps-text: #1E293B;
            --cnps-text-muted: #64748B;
        }

        * { font-family: 'Inter', system-ui, sans-serif; box-sizing: border-box; }

        body {
            background: var(--cnps-bg);
            margin: 0;
            min-height: 100vh;
            color: var(--cnps-text);
            font-size: 14px;
        }

        .app-layout {
            display: flex;
            min-height: 100vh;
        }

        /* ===== SIDEBAR (étroite, comme la maquette) ===== */
        .sidebar {
            width: 200px;
            background: white;
            border-right: 1px solid var(--cnps-border);
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .sidebar-brand {
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid var(--cnps-border);
        }

        .sidebar-brand-logo {
            width: 100px;
            height: auto;
            display: block;
        }

        .sidebar-brand-text {
            font-weight: 700;
            font-size: 14px;
            color: var(--cnps-primary);
        }

        .sidebar-nav {
            padding: 16px 12px;
            flex: 1;
        }

        .sidebar-nav a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            color: var(--cnps-text-muted);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            border-radius: 6px;
            margin-bottom: 2px;
            transition: all 0.15s;
        }

        .sidebar-nav a:hover {
            background: #F1F5F9;
            color: var(--cnps-text);
        }

        .sidebar-nav a.active {
            background: #F1F5F9;
            color: var(--cnps-primary);
            font-weight: 600;
        }

        .sidebar-nav i {
            font-size: 16px;
            width: 18px;
            text-align: center;
        }

        .sidebar-footer {
            padding: 14px;
            border-top: 1px solid var(--cnps-border);
        }

        .role-card {
            background: #F8FAFC;
            border: 1px solid var(--cnps-border);
            border-radius: 8px;
            padding: 10px 12px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .role-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--cnps-primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .role-info {
            font-size: 11px;
            line-height: 1.3;
            min-width: 0;
        }

        .role-info .role-label {
            color: var(--cnps-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-size: 9px;
        }

        .role-info .role-name {
            font-weight: 600;
            color: var(--cnps-text);
            font-size: 12px;
        }

        /* ===== MAIN AREA ===== */
        .main-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .topbar {
            background: transparent;
            padding: 20px 32px 0;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 14px;
        }

        .topbar-bell {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: white;
            border: 1px solid var(--cnps-border);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--cnps-text-muted);
            cursor: pointer;
            position: relative;
        }

        .topbar-bell::after {
            content: '';
            position: absolute;
            top: 8px;
            right: 10px;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--cnps-accent);
            border: 2px solid white;
        }

        .topbar-user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--cnps-primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 12px;
            cursor: pointer;
        }

        .main-content {
            padding: 24px 32px 32px;
            flex: 1;
        }

        /* ===== TYPOGRAPHIE ===== */
        .page-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--cnps-text);
            margin: 0 0 4px;
            letter-spacing: -0.3px;
        }

        .page-subtitle {
            color: var(--cnps-text-muted);
            font-size: 14px;
            margin: 0 0 24px;
        }

        /* ===== CARDS ===== */
        .cnps-card {
            background: white;
            border: 1px solid var(--cnps-border);
            border-radius: 12px;
            padding: 20px;
        }

        /* ===== UTILS ===== */
        .text-cnps { color: var(--cnps-primary) !important; }
        .text-teal { color: var(--cnps-teal) !important; }
        .text-muted-cnps { color: var(--cnps-text-muted) !important; }
        .bg-cnps { background: var(--cnps-primary) !important; }

        .btn-cnps {
            background: var(--cnps-primary);
            color: white;
            border: none;
            font-weight: 600;
            padding: 10px 18px;
            border-radius: 8px;
            font-size: 13px;
        }
        .btn-cnps:hover { background: var(--cnps-primary-dark); color: white; }

        .label-uppercase {
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-size: 11px;
            font-weight: 600;
            color: var(--cnps-text-muted);
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% block layout %}
        <div class="app-layout">
            {# ===== SIDEBAR ===== #}
            <aside class="sidebar">
                <div class="sidebar-brand">
                    <img src="{{ asset('images/logo-cnps.jpg') }}" alt="CNPS" class="sidebar-brand-logo">
                </div>

                <nav class="sidebar-nav">
                    {# Tableau de bord : tout le monde voit le sien #}
                    <a href="{{ path('app_dashboard') }}" class="{{ app.request.attributes.get('_route') starts with 'app_dashboard' ? 'active' : '' }}">
                        <i class="bi bi-grid"></i> Tableau
                    </a>

                    {# Recommandations : tout authentifié, contenu filtré par rôle dans le contrôleur #}
                    <a href="{{ path('app_recommendation_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_recommendation' ? 'active' : '' }}">
                        <i class="bi bi-file-text"></i> Recommandations
                    </a>

                    {# Séances : Admin, Secrétaire, Coordonnateur #}
                    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SECRETARY') or is_granted('ROLE_COORDINATOR') %}
                        <a href="{{ path('app_meeting_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_meeting' ? 'active' : '' }}">
                            <i class="bi bi-calendar3"></i> Séances
                        </a>
                    {% endif %}

                    {# Validation : Admin seul (vieille maquette, on la cache aux autres) #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_validation_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_validation' ? 'active' : '' }}">
                            <i class="bi bi-shield-check"></i> Validation
                        </a>
                    {% endif %}

                    {# Section ADMIN — référentiel organisationnel #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_structure_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_structure' ? 'active' : '' }}">
                            <i class="bi bi-buildings"></i> Structures
                        </a>
                        <a href="{{ path('app_department_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_department' ? 'active' : '' }}">
                            <i class="bi bi-diagram-3"></i> Services
                        </a>
                        <a href="{{ path('app_user_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_user' ? 'active' : '' }}">
                            <i class="bi bi-people"></i> Agents
                        </a>
                    {% endif %}

                    {# Mon compte : tout le monde #}
                    <a href="{{ path('app_account') }}" class="{{ app.request.attributes.get('_route') == 'app_account' ? 'active' : '' }}">
                        <i class="bi bi-person-circle"></i> Compte
                    </a>
                </nav>

                <div class="sidebar-footer">
                    <div class="role-card">
                        <div class="role-avatar">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <div class="role-info">
    <div class="role-label">RÔLE ACTUEL</div>
    <div class="role-name">{% if app.user %}{{ app.user.mainRoleLabel }}{% else %}Visiteur{% endif %}</div>
</div>
                    </div>
                </div>
            </aside>

            {# ===== MAIN ===== #}
            <div class="main-area">
                <header class="topbar">
                    <div class="topbar-bell">
                        <i class="bi bi-bell"></i>
                    </div>
                   {% if app.user %}
    <div class="dropdown">
        <button class="topbar-user-avatar dropdown-toggle border-0 bg-transparent p-0" data-bs-toggle="dropdown" style="background: var(--cnps-primary) !important;">
            {{ app.user.initials }}
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
            <li><h6 class="dropdown-header">{{ app.user.fullName }}</h6></li>
            <li><span class="dropdown-item-text small text-muted">{{ app.user.mainRoleLabel }}</span></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="{{ path('app_account') }}"><i class="bi bi-person-circle me-2"></i>Mon compte</a></li>
            <li><a class="dropdown-item text-danger" href="{{ path('app_login') }}"><i class="bi bi-box-arrow-right me-2"></i>Déconnexion</a></li>
        </ul>
    </div>
{% endif %}
                </header>

                <main class="main-content">
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label }} alert-dismissible fade show">
                                {{ message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endfor %}
                    {% endfor %}

                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
    {% endblock %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>