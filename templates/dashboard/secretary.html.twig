{% extends 'base.html.twig' %}
{% block title %}Mon tableau de bord — CNPS{% endblock %}

{% block stylesheets %}
<style>
    .role-banner { background: linear-gradient(135deg, #1F4E79, #163958); color: white; border-radius: 10px; padding: 22px 26px; margin-bottom: 22px; }
    .role-banner h2 { font-size: 19px; font-weight: 700; margin: 0; }
    .role-banner p { font-size: 13px; opacity: 0.85; margin: 4px 0 0; }

    /* Gros boutons d'action principaux */
    .big-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 22px; }
    .big-action {
        background: white; border: 2px solid var(--cnps-border); border-radius: 12px;
        padding: 24px; text-decoration: none; color: var(--cnps-text);
        display: flex; align-items: center; gap: 18px;
        transition: all 0.15s;
    }
    .big-action:hover {
        border-color: var(--cnps-primary); background: #F8FAFC; color: var(--cnps-primary);
        transform: translateY(-1px); box-shadow: 0 4px 12px rgba(31,78,121,0.08);
    }
    .big-action-icon {
        width: 56px; height: 56px; border-radius: 12px;
        background: var(--cnps-primary); color: white;
        display: flex; align-items: center; justify-content: center;
        font-size: 26px; flex-shrink: 0;
    }
    .big-action.teal .big-action-icon { background: var(--cnps-teal); }
    .big-action-text { flex: 1; }
    .big-action-title { font-weight: 700; font-size: 16px; }
    .big-action-sub { font-size: 12px; color: var(--cnps-text-muted); margin-top: 2px; }

    .mini-kpi { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 22px; }
    .mini-kpi-card { background: white; border: 1px solid var(--cnps-border); border-radius: 10px; padding: 16px 18px; border-left: 4px solid var(--cnps-primary); }
    .mini-kpi-value { font-size: 28px; font-weight: 800; color: var(--cnps-text); }
    .mini-kpi-label { font-size: 11px; color: var(--cnps-text-muted); text-transform: uppercase; letter-spacing: 0.4px; margin-top: 2px; }

    .item-line { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #F1F5F9; }
    .item-line:last-child { border-bottom: none; }
    .item-meta { font-size: 11px; color: var(--cnps-text-muted); }
    .pill { font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 10px; background: #F1F5F9; color: #475569; }
    .pill.audit { background: #FEE2E2; color: #991B1B; }
    .pill.reunion { background: #DBEAFE; color: #1E40AF; }
    .pill.comite { background: #DCFCE7; color: #15803D; }
    .section-empty { padding: 30px; text-align: center; color: var(--cnps-text-muted); font-size: 13px; }
    .section-empty i { font-size: 32px; color: #CBD5E1; display: block; margin-bottom: 8px; }
</style>
{% endblock %}

{% block body %}
    <div class="role-banner">
        <h2><i class="bi bi-journal-text"></i> Secrétaire de séance</h2>
        <p>{{ user.fullName }} — Comité des projets</p>
    </div>

    {# GROS BOUTONS D'ACTION : les 2 choses qu'il fait au quotidien #}
    <div class="big-actions">
        <a href="{{ path('app_meeting_new') }}" class="big-action">
            <div class="big-action-icon"><i class="bi bi-calendar-plus"></i></div>
            <div class="big-action-text">
                <div class="big-action-title">Créer une séance</div>
                <div class="big-action-sub">Audit, COPIL, réunion de direction…</div>
            </div>
        </a>
        <a href="{{ path('app_recommendation_new') }}" class="big-action teal">
            <div class="big-action-icon"><i class="bi bi-plus-circle"></i></div>
            <div class="big-action-text">
                <div class="big-action-title">Saisir une recommandation</div>
                <div class="big-action-sub">À l'issue d'une séance tenue</div>
            </div>
        </a>
    </div>

    {# COMPTEURS #}
    <div class="mini-kpi">
        <div class="mini-kpi-card">
            <div class="mini-kpi-value">{{ total_meetings }}</div>
            <div class="mini-kpi-label">Séances au total</div>
        </div>
        <div class="mini-kpi-card">
            <div class="mini-kpi-value">{{ upcoming_meetings|length }}</div>
            <div class="mini-kpi-label">Séances planifiées</div>
        </div>
        <div class="mini-kpi-card">
            <div class="mini-kpi-value">{{ draft_recos|length }}</div>
            <div class="mini-kpi-label">Recos en attente de validation</div>
        </div>
    </div>

    <div class="row g-3">
        {# Séances à venir #}
        <div class="col-md-6">
            <div class="cnps-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-calendar3"></i> Séances à venir</h6>
                    <a href="{{ path('app_meeting_index') }}" class="small text-decoration-none">Voir tout →</a>
                </div>
                {% for meeting in upcoming_meetings %}
                    <div class="item-line">
                        <div class="flex-grow-1">
                            <a href="{{ path('app_meeting_edit', {id: meeting.id}) }}" class="fw-semibold text-decoration-none">{{ meeting.title }}</a>
                            <div class="item-meta">{{ meeting.scheduledAt|date('d/m/Y à H:i') }} · {{ meeting.location ?: 'Lieu non précisé' }}</div>
                        </div>
                        <span class="pill {{ meeting.type == 'audit_interne' ? 'audit' : (meeting.type == 'reunion_direction' ? 'reunion' : 'comite') }}">
                            {{ meeting.type|replace({'_': ' '})|title }}
                        </span>
                    </div>
                {% else %}
                    <div class="section-empty">
                        <i class="bi bi-calendar-x"></i>
                        Aucune séance planifiée.
                    </div>
                {% endfor %}
            </div>
        </div>

        {# Recos en attente de validation #}
        <div class="col-md-6">
            <div class="cnps-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-hourglass-split"></i> Recos en attente de validation</h6>
                    <a href="{{ path('app_recommendation_index') }}" class="small text-decoration-none">Voir tout →</a>
                </div>
                <p class="text-muted-cnps small mb-3">Recommandations saisies, en attente de validation par le coordonnateur.</p>
                {% for reco in draft_recos %}
                    <div class="item-line">
                        <div class="flex-grow-1">
                            <a href="{{ path('app_recommendation_show', {reference: reco.reference}) }}" class="fw-semibold text-decoration-none">{{ reco.label }}</a>
                            <div class="item-meta">{{ reco.reference }} · {{ reco.createdAt|date('d/m/Y') }}</div>
                        </div>
                        <span class="pill">{{ reco.statusLabel }}</span>
                    </div>
                {% else %}
                    <div class="section-empty">
                        <i class="bi bi-check2-circle"></i>
                        Aucune recommandation en attente.
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Recos récentes pour info #}
    <div class="cnps-card mt-3">
        <h6 class="fw-bold mb-3"><i class="bi bi-clock-history"></i> Recommandations récentes</h6>
        {% for reco in recent_recos %}
            <div class="item-line">
                <div class="flex-grow-1">
                    <a href="{{ path('app_recommendation_show', {reference: reco.reference}) }}" class="fw-semibold text-decoration-none">{{ reco.label }}</a>
                    <div class="item-meta">{{ reco.reference }} · {{ reco.createdAt|date('d/m/Y') }}</div>
                </div>
                <span class="pill">{{ reco.statusLabel }}</span>
            </div>
        {% else %}
            <div class="section-empty">
                <i class="bi bi-inbox"></i>
                Aucune recommandation enregistrée.
            </div>
        {% endfor %}
    </div>
{% endblock %}
