{% extends 'base.html.twig' %}
{% block title %}Affecter à un agent — {{ reco.reference }}{% endblock %}

{% block stylesheets %}
<style>
    .form-card { background: white; border: 1px solid var(--cnps-border); border-radius: 12px; padding: 28px; max-width: 720px; margin: 0 auto; }
    .reco-summary { background: #F8FAFC; border-left: 4px solid var(--cnps-primary); padding: 14px 18px; border-radius: 6px; margin-bottom: 24px; }
    .reco-summary .ref { font-size: 11px; color: var(--cnps-text-muted); font-weight: 600; letter-spacing: 0.4px; text-transform: uppercase; }
    .reco-summary .label { font-size: 15px; font-weight: 700; color: var(--cnps-text); margin-top: 4px; }
    .form-label { font-weight: 600; font-size: 13px; color: var(--cnps-text); margin-bottom: 6px; }
    .form-select, .form-control { font-size: 14px; }
    .agent-empty { padding: 20px; text-align: center; color: var(--cnps-text-muted); background: #F8FAFC; border-radius: 8px; }
</style>
{% endblock %}

{% block body %}
    <div class="d-flex align-items-center mb-3">
        <a href="{{ path('app_recommendation_show', {reference: reco.reference}) }}" class="text-decoration-none text-muted-cnps">
            <i class="bi bi-arrow-left"></i> Retour à la recommandation
        </a>
    </div>

    <div class="form-card">
        <h4 class="fw-bold mb-1">Affecter à un agent</h4>
        <p class="text-muted-cnps small mb-4">Désignez l'agent de votre service qui sera chargé de mettre en application cette recommandation.</p>

        <div class="reco-summary">
            <div class="ref">{{ reco.reference }} · {{ reco.statusLabel }}</div>
            <div class="label">{{ reco.label }}</div>
            {% if reco.dueDate %}
                <div class="small text-muted-cnps mt-2"><i class="bi bi-calendar"></i> Échéance : {{ reco.dueDate|date('d/m/Y') }}</div>
            {% endif %}
        </div>

        {% if agents is empty %}
            <div class="agent-empty">
                <i class="bi bi-person-x" style="font-size: 28px; display: block; margin-bottom: 8px; color: #CBD5E1;"></i>
                Aucun agent disponible dans la structure « {{ reco.assignedStructure ? reco.assignedStructure.label : 'inconnue' }} ».
                <div class="small mt-2">Veuillez d'abord créer des comptes agents pour cette structure.</div>
            </div>
        {% else %}
            <form method="post" action="{{ path('app_recommendation_assign_agent', {reference: reco.reference}) }}">
                <div class="mb-3">
                    <label for="agent_id" class="form-label">Agent désigné <span class="text-danger">*</span></label>
                    <select name="agent_id" id="agent_id" class="form-select" required>
                        <option value="">— Sélectionner un agent —</option>
                        {% for agent in agents %}
                            <option value="{{ agent.id }}">{{ agent.fullName }} ({{ agent.email }})</option>
                        {% endfor %}
                    </select>
                    <div class="form-text">Agents rattachés à : {{ reco.assignedStructure ? reco.assignedStructure.label : 'aucune structure' }}</div>
                </div>

                <div class="mb-4">
                    <label for="comment" class="form-label">Commentaire d'affectation (facultatif)</label>
                    <textarea name="comment" id="comment" class="form-control" rows="3" placeholder="Précisions ou instructions à l'agent…"></textarea>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a href="{{ path('app_recommendation_show', {reference: reco.reference}) }}" class="btn btn-outline-secondary">Annuler</a>
                    <button type="submit" class="btn btn-cnps">
                        <i class="bi bi-person-check"></i> Affecter et démarrer le traitement
                    </button>
                </div>
            </form>
        {% endif %}
    </div>
{% endblock %}
