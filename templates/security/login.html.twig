<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion — CNPS Suivi des Recommandations</title>
    <link rel="icon" type="image/jpeg" href="{{ asset('favicon.jpg') }}">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --cnps-primary: #1F4E79;
            --cnps-primary-dark: #163958;
            --cnps-teal: #14B8A6;
            --cnps-yellow: #FFC107;
        }
        * { font-family: 'Inter', system-ui, sans-serif; box-sizing: border-box; }
        body {
            margin: 0; min-height: 100vh;
            background: linear-gradient(135deg, #1F4E79 0%, #163958 50%, #0F172A 100%);
            position: relative; overflow-x: hidden;
        }
        .login-container {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            padding: 24px; position: relative; z-index: 1;
        }
        .login-wrapper {
            display: grid; grid-template-columns: 1fr 1fr;
            max-width: 1000px; width: 100%; background: white;
            border-radius: 20px; overflow: hidden;
            box-shadow: 0 25px 70px rgba(0, 0, 0, 0.3);
        }
        .login-left {
            background: linear-gradient(135deg, #1F4E79 0%, #163958 100%);
            color: white; padding: 50px 40px;
            display: flex; flex-direction: column;
        }
        .brand { display: flex; align-items: center; gap: 12px; }
        .brand-logo {
            height: 48px; width: auto; display: block;
        }
        .brand-text { font-weight: 700; font-size: 18px; }
        .brand-text small { display: block; font-weight: 400; font-size: 12px; opacity: 0.8; }
        .login-left-content {
            flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 40px 0;
        }
        .login-left-content h1 { font-size: 32px; font-weight: 800; line-height: 1.2; margin-bottom: 16px; }
        .login-left-content p { font-size: 14px; line-height: 1.6; opacity: 0.85; margin-bottom: 32px; }
        .features-list { list-style: none; padding: 0; margin: 0; }
        .features-list li { display: flex; align-items: center; gap: 12px; padding: 8px 0; font-size: 14px; opacity: 0.9; }
        .features-list li i { color: var(--cnps-teal); font-size: 18px; }
        .login-left-footer {
            padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1);
            font-size: 11px; opacity: 0.6;
        }
        .login-right { padding: 60px 50px; display: flex; flex-direction: column; justify-content: center; }
        .login-right h2 { font-size: 28px; font-weight: 700; color: #1E293B; margin-bottom: 6px; }
        .login-right .subtitle { color: #64748B; font-size: 14px; margin-bottom: 32px; }
        .form-label {
            font-size: 12px; font-weight: 600; color: #334155; margin-bottom: 8px;
            text-transform: uppercase; letter-spacing: 0.5px;
        }
        .form-control {
            padding: 12px 14px 12px 42px; border: 1px solid #E2E8F0;
            border-radius: 10px; font-size: 14px; width: 100%;
        }
        .form-control:focus { border-color: var(--cnps-primary); box-shadow: 0 0 0 4px rgba(31,78,121,0.1); outline: none; }
        .input-icon { position: relative; }
        .input-icon > i.bi-envelope, .input-icon > i.bi-lock {
            position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
            color: #94A3B8; font-size: 16px; pointer-events: none;
        }
        .form-options { display: flex; justify-content: space-between; align-items: center; margin: 16px 0 24px; }
        .remember-me { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #475569; }
        .forgot-link { font-size: 13px; color: var(--cnps-primary); text-decoration: none; font-weight: 600; }
        .btn-login {
            width: 100%; background: var(--cnps-primary); color: white; border: none;
            padding: 14px; border-radius: 10px; font-weight: 700; font-size: 15px;
            cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-login:hover { background: var(--cnps-primary-dark); }
        .login-divider { text-align: center; margin: 24px 0; position: relative; }
        .login-divider::before { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: #E2E8F0; }
        .login-divider span { background: white; padding: 0 14px; font-size: 12px; color: #94A3B8; position: relative; }
        .sso-btn {
            width: 100%; background: white; color: #334155; border: 1.5px solid #E2E8F0;
            padding: 12px; border-radius: 10px; font-weight: 600; font-size: 14px;
            cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 10px;
        }
        .sso-btn:hover { border-color: var(--cnps-primary); background: #F8FAFC; color: var(--cnps-primary); }
        .help-text { text-align: center; font-size: 12px; color: #94A3B8; margin-top: 24px; }
        .alert-error {
            background: #FEE2E2; border: 1px solid #FCA5A5; color: #991B1B;
            padding: 12px 16px; border-radius: 10px; font-size: 13px; margin-bottom: 20px;
            display: flex; align-items: center; gap: 10px;
        }
        @media (max-width: 900px) {
            .login-wrapper { grid-template-columns: 1fr; max-width: 480px; }
            .login-left { padding: 30px; }
            .login-right { padding: 40px 30px; }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-wrapper">
            <div class="login-left">
                <div class="brand">
                    <img src="{{ asset('images/logo-cnps.jpg') }}" alt="CNPS" class="brand-logo">
                </div>
                <div class="login-left-content">
                    <h1>Bienvenue dans votre espace de pilotage</h1>
                    <p>Suivez en temps réel l'avancement des recommandations issues des audits et des séances institutionnelles.</p>
                    <ul class="features-list">
                        <li><i class="bi bi-check-circle-fill"></i> Tableau de bord stratégique consolidé</li>
                        <li><i class="bi bi-check-circle-fill"></i> Circuit hiérarchique de validation</li>
                        <li><i class="bi bi-check-circle-fill"></i> Relances automatiques et notifications</li>
                        <li><i class="bi bi-check-circle-fill"></i> Traçabilité complète des actions</li>
                    </ul>
                </div>
                <div class="login-left-footer">
                    © 2026 Caisse Nationale de Prévoyance Sociale<br>
                    Direction des Systèmes d'Information
                </div>
            </div>

            <div class="login-right">
                <h2>Connexion</h2>
                <p class="subtitle">Accédez à votre espace personnel sécurisé</p>

                {% if error %}
                    <div class="alert-error">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    </div>
                {% endif %}

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Adresse email</label>
                        <div class="input-icon">
                            <i class="bi bi-envelope"></i>
                            <input type="email" name="_username" class="form-control" placeholder="prenom.nom@cnps.cm" value="{{ last_username|default('') }}" autocomplete="email" autofocus required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mot de passe</label>
                        <div class="input-icon">
                            <i class="bi bi-lock"></i>
                            <input type="password" name="_password" id="passwordField" class="form-control" placeholder="Votre mot de passe" autocomplete="current-password" style="padding-right: 42px;" required>
                            <i class="bi bi-eye" id="togglePassword" style="position: absolute; right: 14px; top: 50%; transform: translateY(-50%); color: #94A3B8; cursor: pointer;"></i>
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="form-options">
                        <label class="remember-me">
                            <input type="checkbox" name="_remember_me"> Se souvenir de moi
                        </label>
                        <a href="#" class="forgot-link">Mot de passe oublié ?</a>
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="bi bi-shield-check"></i> Se connecter
                    </button>

                    <div class="login-divider"><span>OU</span></div>

                    <button type="button" class="sso-btn">
                        <i class="bi bi-building"></i> Connexion via Active Directory CNPS
                    </button>
                </form>

                <p class="help-text">
                    Problème de connexion ? Contactez le
                    <a href="#" style="color: var(--cnps-primary); font-weight: 600; text-decoration: none;">Support DSI</a>
                </p>
            </div>
        </div>
    </div>

    <script>
        const toggle = document.getElementById('togglePassword');
        const field = document.getElementById('passwordField');
        toggle.addEventListener('click', function () {
            const isHidden = field.getAttribute('type') === 'password';
            field.setAttribute('type', isHidden ? 'text' : 'password');
            toggle.classList.toggle('bi-eye');
            toggle.classList.toggle('bi-eye-slash');
        });
    </script>
</body>
</html>
