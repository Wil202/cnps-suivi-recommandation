{{ form_start(form) }}
    <div class="row">
        <div class="col-md-6 mb-3">
            {{ form_label(form.firstName, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
            {{ form_widget(form.firstName, {attr: {class: 'form-control'}}) }}
            <div class="text-danger small mt-1">{{ form_errors(form.firstName) }}</div>
        </div>
        <div class="col-md-6 mb-3">
            {{ form_label(form.lastName, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
            {{ form_widget(form.lastName, {attr: {class: 'form-control'}}) }}
            <div class="text-danger small mt-1">{{ form_errors(form.lastName) }}</div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-7 mb-3">
            {{ form_label(form.email, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
            {{ form_widget(form.email, {attr: {class: 'form-control'}}) }}
            <div class="text-danger small mt-1">{{ form_errors(form.email) }}</div>
        </div>
        <div class="col-md-5 mb-3">
            {{ form_label(form.matricule, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
            {{ form_widget(form.matricule, {attr: {class: 'form-control'}}) }}
        </div>
    </div>

    <div class="mb-3">
        {{ form_label(form.role, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.role, {attr: {class: 'form-select'}}) }}
        {% if form.role.vars.help %}<small class="text-muted-cnps">{{ form.role.vars.help }}</small>{% endif %}
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            {{ form_label(form.structure, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
            {{ form_widget(form.structure, {attr: {class: 'form-select'}}) }}
        </div>
        <div class="col-md-6 mb-3">
            {{ form_label(form.department, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
            {{ form_widget(form.department, {attr: {class: 'form-select'}}) }}
        </div>
    </div>

    <div class="mb-3">
        {{ form_label(form.plainPassword, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.plainPassword, {attr: {class: 'form-control'}}) }}
        <div class="text-danger small mt-1">{{ form_errors(form.plainPassword) }}</div>
    </div>

    <div class="mb-4">
        <div class="form-check">
            {{ form_widget(form.active, {attr: {class: 'form-check-input'}}) }}
            {{ form_label(form.active, null, {label_attr: {class: 'form-check-label'}}) }}
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-cnps">
            <i class="bi bi-check-lg"></i> {{ button_label|default('Enregistrer') }}
        </button>
        <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary">Annuler</a>
    </div>
{{ form_end(form) }}
