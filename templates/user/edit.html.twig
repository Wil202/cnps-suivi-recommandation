{% extends 'base.html.twig' %}
{% block title %}Modifier {{ user.fullName }} — CNPS{% endblock %}
{% block body %}
    <div class="mb-3">
        <a href="{{ path('app_user_index') }}" class="text-decoration-none text-muted-cnps small">
            <i class="bi bi-arrow-left"></i> Retour aux agents
        </a>
    </div>
    <h1 class="page-title mb-4">Modifier l'agent {{ user.fullName }}</h1>
    <div class="cnps-card mb-3" style="max-width: 680px;">
        {{ include('user/_form.html.twig', {button_label: 'Enregistrer les modifications'}) }}
    </div>
    <div class="cnps-card" style="max-width: 680px; border-color: #FCA5A5;">
        <h6 class="fw-bold text-danger mb-1">Zone de danger</h6>
        <p class="text-muted-cnps small mb-3">La suppression d'un agent est définitive.</p>
        {{ include('user/_delete_form.html.twig') }}
    </div>
{% endblock %}
